# Optional: `apps/web/.env.local` (gitignored) overrides `.env.development` for `pnpm dev`.
#
# Create / refresh `.env.local` to point dev frontend at **production** signaling (from repo root):
#   printf '%s\n' 'VITE_SIGNALING_URL=wss://tg-signaling.1057674027.workers.dev' > apps/web/.env.local
#
# Copy this file then edit (alternative):
#   cp apps/web/.env.example apps/web/.env.local
#
# Production signaling (Cloudflare Workers) — same value as `apps/web/.env.production`
# VITE_SIGNALING_URL=wss://tg-signaling.1057674027.workers.dev
#
# Local Cloudflare Worker (`pnpm sig:dev`, port 8787) — put in `.env.local` to override dev default
# VITE_SIGNALING_URL=ws://localhost:8787
#
# Local Node broker (`pnpm dev:all`, port 4001)
# VITE_SIGNALING_URL=ws://localhost:4001

VITE_SIGNALING_URL=ws://localhost:8787
