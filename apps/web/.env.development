# Default for `pnpm dev`: use production signaling so WebSocket works without `pnpm sig:dev`.
# Matches `apps/web/.env.production` (Cloudflare Workers).
VITE_SIGNALING_URL=wss://tg-signaling.1057674027.workers.dev

# Local overrides (gitignored `apps/web/.env.local`):
#   Local Worker — `pnpm sig:dev` → VITE_SIGNALING_URL=ws://localhost:8787
#   Legacy Node — `pnpm dev:all` → VITE_SIGNALING_URL=ws://localhost:4001
